# Safe example configuration. Copy to .env for local use.

OPENMARKET_DB_PATH=data/openmarket.db
OPENMARKET_BINANCE_WS_PORT=8001
OPENMARKET_POLYMARKET_WS_PORT=8002
OPENMARKET_SIGNAL_ENGINE_PORT=8003
OPENMARKET_EXECUTION_ENGINE_PORT=8004
OPENMARKET_RECORDER_PORT=8005

# Live execution is disabled by default in public examples.
OPENMARKET_EXECUTION_MODE=paper
OPENMARKET_PRIVATE_KEY=
OPENMARKET_POLYMARKET_API_KEY=
OPENMARKET_POLYMARKET_API_SECRET=
OPENMARKET_POLYMARKET_API_PASSPHRASE=
